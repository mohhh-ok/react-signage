{
    "name": "@masa-dev/react-signage",
    "version": "3.5.11",
    "description": "This is a react library for signage.",
    "keywords": [
        "react",
        "signage",
        "video",
        "image"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "test": "vitest run",
        "build": "tsc && pnpm run copy",
        "dev": "tsc --watch & pnpm run copy:watch",
        "copy": "cpx \"src/**/*.css\" dist",
        "copy:watch": "cpx \"src/**/*.css\" dist --watch",
        "release": "release-it"
    },
    "author": "masa-dev",
    "license": "MIT",
    "dependencies": {
        "@react-spring/web": "^10.0.3",
        "axios": "^1.16.1",
        "dexie": "^4.4.2",
        "react-hot-toast": "^2.6.0"
    },
    "peerDependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "release-it": {
        "hooks": {
            "before:init": [
                "pnpm run test"
            ],
            "before:release": [
                "pnpm run build"
            ]
        }
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@tsconfig/node20": "^20.1.9",
        "@types/react": "^19.2.14",
        "cpx2": "^8.0.2",
        "fake-indexeddb": "^6.2.5",
        "jsdom": "^29.1.1",
        "release-it": "^20.0.1",
        "vitest": "^4.1.6"
    }
}
